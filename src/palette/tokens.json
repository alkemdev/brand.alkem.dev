{
  "$schema": "https://alkemdev.github.io/brand/tokens.schema.json",
  "meta": {
    "name": "Alkemical Development",
    "version": "0.1.0",
    "description": "Design tokens for the Alkemical Development brand"
  },

  "color": {
    "primitive": {
      "gold": {
        "50":  "#fdf8ed",
        "100": "#f9eccc",
        "200": "#f3d994",
        "300": "#ecc55c",
        "400": "#e5b233",
        "500": "#d4990f",
        "600": "#b8790a",
        "700": "#935b0b",
        "800": "#6e4410",
        "900": "#4a2e0e"
      },
      "obsidian": {
        "50":  "#f4f4f6",
        "100": "#e4e4e8",
        "200": "#c8c9d1",
        "300": "#a1a3b0",
        "400": "#71748a",
        "500": "#4e5169",
        "600": "#3a3c52",
        "700": "#2b2d40",
        "800": "#1d1e2e",
        "900": "#11121e",
        "950": "#0a0b14"
      },
      "ember": {
        "50":  "#fef3ed",
        "100": "#fce0cc",
        "200": "#f9bd94",
        "300": "#f5965c",
        "400": "#f17433",
        "500": "#d95a1a",
        "600": "#b54412",
        "700": "#8c3310",
        "800": "#662510",
        "900": "#44190d"
      },
      "azure": {
        "50":  "#eef3fa",
        "100": "#d4e2f4",
        "200": "#a9c5e9",
        "300": "#7ba5db",
        "400": "#5488cc",
        "500": "#3668b0",
        "600": "#2a5290",
        "700": "#213e6e",
        "800": "#192c4e",
        "900": "#111d34"
      },
      "white":  "#fafaf9",
      "black":  "#0a0b14"
    },

    "semantic": {
      "primary":     "{color.primitive.gold.500}",
      "primary-light": "{color.primitive.gold.300}",
      "primary-dark":  "{color.primitive.gold.700}",

      "secondary":     "{color.primitive.azure.500}",
      "secondary-light": "{color.primitive.azure.300}",
      "secondary-dark":  "{color.primitive.azure.700}",

      "accent":       "{color.primitive.ember.500}",
      "accent-light": "{color.primitive.ember.300}",
      "accent-dark":  "{color.primitive.ember.700}",

      "surface":      "{color.primitive.obsidian.950}",
      "surface-raised": "{color.primitive.obsidian.900}",
      "surface-overlay": "{color.primitive.obsidian.800}",

      "text":         "{color.primitive.white}",
      "text-muted":   "{color.primitive.obsidian.300}",
      "text-inverse": "{color.primitive.obsidian.950}",

      "border":       "{color.primitive.obsidian.700}",
      "border-subtle": "{color.primitive.obsidian.800}"
    }
  },

  "typography": {
    "family": {
      "display": "\"Martian Grotesk\", system-ui, sans-serif",
      "body":    "\"Inter\", system-ui, sans-serif",
      "mono":    "\"JetBrains Mono\", ui-monospace, monospace"
    },
    "weight": {
      "light":    300,
      "regular":  400,
      "medium":   500,
      "semibold": 600,
      "bold":     700,
      "black":    900
    },
    "scale": {
      "xs":   "0.75rem",
      "sm":   "0.875rem",
      "base": "1rem",
      "lg":   "1.125rem",
      "xl":   "1.25rem",
      "2xl":  "1.5rem",
      "3xl":  "1.875rem",
      "4xl":  "2.25rem",
      "5xl":  "3rem",
      "6xl":  "3.75rem",
      "7xl":  "4.5rem"
    },
    "lineHeight": {
      "tight":   1.1,
      "snug":    1.3,
      "normal":  1.5,
      "relaxed": 1.625,
      "loose":   2.0
    },
    "letterSpacing": {
      "tighter": "-0.04em",
      "tight":   "-0.02em",
      "normal":  "0em",
      "wide":    "0.02em",
      "wider":   "0.04em",
      "widest":  "0.08em"
    }
  },

  "spacing": {
    "0":   "0",
    "px":  "1px",
    "0.5": "0.125rem",
    "1":   "0.25rem",
    "1.5": "0.375rem",
    "2":   "0.5rem",
    "3":   "0.75rem",
    "4":   "1rem",
    "5":   "1.25rem",
    "6":   "1.5rem",
    "8":   "2rem",
    "10":  "2.5rem",
    "12":  "3rem",
    "16":  "4rem",
    "20":  "5rem",
    "24":  "6rem",
    "32":  "8rem",
    "40":  "10rem",
    "48":  "12rem",
    "64":  "16rem"
  },

  "radius": {
    "none": "0",
    "sm":   "0.25rem",
    "md":   "0.5rem",
    "lg":   "0.75rem",
    "xl":   "1rem",
    "2xl":  "1.5rem",
    "full": "9999px"
  },

  "shadow": {
    "sm":  "0 1px 2px 0 rgba(10, 11, 20, 0.4)",
    "md":  "0 4px 6px -1px rgba(10, 11, 20, 0.4), 0 2px 4px -2px rgba(10, 11, 20, 0.3)",
    "lg":  "0 10px 15px -3px rgba(10, 11, 20, 0.4), 0 4px 6px -4px rgba(10, 11, 20, 0.3)",
    "xl":  "0 20px 25px -5px rgba(10, 11, 20, 0.4), 0 8px 10px -6px rgba(10, 11, 20, 0.3)",
    "glow-gold":  "0 0 20px rgba(212, 153, 15, 0.3)",
    "glow-ember": "0 0 20px rgba(217, 90, 26, 0.3)"
  }
}
