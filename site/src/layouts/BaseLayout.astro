---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Brand guidelines for Alkemical Development" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title} — Alkemical Development</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <nav class="site-nav">
      <a href="/" class="nav-brand">Alkemical Development</a>
      <div class="nav-links">
        <a href="/explorer">Logo Explorer</a>
        <a href="/identity">Identity</a>
        <a href="/color">Color</a>
        <a href="/typography">Typography</a>
        <a href="/voice">Voice & Tone</a>
        <a href="/downloads">Downloads</a>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <p>Alkemical Development &middot; Brand Guidelines</p>
      <p class="footer-sub">
        Assets: <a href="https://creativecommons.org/licenses/by-sa/4.0/">CC BY-SA 4.0</a>
        &middot; Code: <a href="https://opensource.org/licenses/MIT">MIT</a>
        &middot; <a href="https://github.com/alkemdev/brand.alkem.dev">Source</a>
      </p>
    </footer>
  </body>
</html>

<style>
  @import "../styles/global.css";

  .site-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--brand-spacing-4) var(--brand-spacing-8);
    border-bottom: 1px solid var(--brand-color-semantic-border);
    background: var(--brand-color-semantic-surface-raised);
  }

  .nav-brand {
    font-family: var(--brand-typography-family-display);
    font-weight: var(--brand-typography-weight-bold);
    font-size: var(--brand-typography-scale-lg);
    color: var(--brand-color-semantic-primary);
  }

  .nav-links {
    display: flex;
    gap: var(--brand-spacing-6);
  }

  .nav-links a {
    font-size: var(--brand-typography-scale-sm);
    font-weight: var(--brand-typography-weight-medium);
    color: var(--brand-color-semantic-text-muted);
    text-transform: uppercase;
    letter-spacing: var(--brand-typography-letterSpacing-wider);
    transition: color 0.15s ease;
  }

  .nav-links a:hover {
    color: var(--brand-color-semantic-text);
  }

  main {
    max-width: 72rem;
    margin: 0 auto;
    padding: var(--brand-spacing-12) var(--brand-spacing-8);
  }

  .site-footer {
    text-align: center;
    padding: var(--brand-spacing-8) var(--brand-spacing-4);
    border-top: 1px solid var(--brand-color-semantic-border);
    color: var(--brand-color-semantic-text-muted);
    font-size: var(--brand-typography-scale-sm);
  }

  .footer-sub {
    margin-top: var(--brand-spacing-2);
    font-size: var(--brand-typography-scale-xs);
  }

  @media (max-width: 640px) {
    .site-nav {
      flex-direction: column;
      gap: var(--brand-spacing-3);
    }

    .nav-links {
      flex-wrap: wrap;
      justify-content: center;
      gap: var(--brand-spacing-3);
    }
  }
</style>
