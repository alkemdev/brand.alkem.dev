---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Brand guidelines for Alkemical Development" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title} — Alkemical Development</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <nav class="site-nav">
      <a href="/" class="nav-brand">Alkemical</a>
      <div class="nav-links">
        <a href="/color">Color</a>
        <a href="/typography">Typography</a>
        <a href="/experiments/flask-3d">3D Flask</a>
        <a href="/downloads">Downloads</a>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <p>Alkemical Development · Brand</p>
      <p class="footer-sub">
        <a href="https://creativecommons.org/licenses/by-sa/4.0/">CC BY-SA 4.0</a>
        · <a href="https://opensource.org/licenses/MIT">MIT</a>
        · <a href="https://github.com/alkemdev/brand.alkem.dev">Source</a>
      </p>
    </footer>
  </body>
</html>

<style>
  @import "../styles/global.css";

  .site-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-4) var(--space-8);
    border-bottom: 1px solid var(--color-border);
    background: var(--color-surface-raised);
  }

  .nav-brand {
    font-family: var(--font-display);
    font-weight: var(--brand-typography-weight-bold);
    font-size: var(--brand-typography-scale-lg);
    color: var(--color-primary);
  }

  .nav-links {
    display: flex;
    gap: var(--space-6);
    flex-wrap: wrap;
  }

  .nav-links a {
    font-size: var(--brand-typography-scale-sm);
    font-weight: var(--brand-typography-weight-medium);
    color: var(--color-text-muted);
    letter-spacing: var(--brand-typography-letterSpacing-wide);
    transition: color 0.15s ease;
  }

  .nav-links a:hover {
    color: var(--color-text);
  }

  main {
    max-width: 72rem;
    margin: 0 auto;
    padding: var(--space-12) var(--space-8);
  }

  .site-footer {
    text-align: center;
    padding: var(--space-8) var(--space-4);
    border-top: 1px solid var(--color-border);
    color: var(--color-text-muted);
    font-size: var(--brand-typography-scale-sm);
  }

  .footer-sub {
    margin-top: var(--space-2);
    font-size: var(--brand-typography-scale-xs);
  }

  .footer-sub a {
    color: var(--color-text-muted);
  }

  .footer-sub a:hover {
    color: var(--color-primary);
  }

  @media (max-width: 768px) {
    .site-nav {
      flex-direction: column;
      gap: var(--space-3);
    }
    .nav-links {
      justify-content: center;
    }
  }
</style>
