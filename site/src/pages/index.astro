---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Brand" description="Alkemical Development brand guidelines.">
  <section class="hero">
    <h1>Alkemical Development</h1>
    <p class="hero-tagline">Open source software, crafted with intention.</p>
  </section>

  <nav class="grid" aria-label="Sections">
    <a href="/color">Color</a>
    <a href="/typography">Typography</a>
    <a href="/experiments/flask-3d">3D Flask</a>
    <a href="/downloads">Downloads</a>
  </nav>
</BaseLayout>

<style>
  .hero {
    padding: var(--space-16) 0 var(--space-12);
  }
  .hero h1 {
    font-size: var(--brand-typography-scale-6xl);
    font-weight: var(--brand-typography-weight-bold);
    line-height: 1.1;
    letter-spacing: var(--brand-typography-letterSpacing-tight);
    color: var(--color-text);
  }
  .hero-tagline {
    margin-top: var(--space-3);
    font-size: var(--brand-typography-scale-xl);
    color: var(--color-primary);
    font-weight: var(--brand-typography-weight-medium);
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(10rem, 1fr));
    gap: var(--space-4);
    padding-bottom: var(--space-16);
  }
  .grid a {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-6);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-surface-raised);
    font-weight: var(--brand-typography-weight-medium);
    color: var(--color-text);
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    text-align: center;
    min-height: 4rem;
  }
  .grid a:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-glow);
  }
</style>
