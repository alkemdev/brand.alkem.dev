---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Identity" description="Logo, marks, and brand identity guidelines for Alkemical Development">
  <section class="page-header">
    <h1>Identity</h1>
    <p>
      The Alkemical Development mark represents transformation — turning raw
      ideas into refined software. The logo is built in Blender and exported
      to multiple formats via our automated pipeline.
    </p>
  </section>

  <section class="section">
    <h2>Logo</h2>
    <div class="logo-display">
      <div class="logo-placeholder">
        <span>Logo assets will appear here once exported.</span>
        <code>just export-logo</code>
      </div>
    </div>
    <p class="note">
      The logo source file lives at <code>src/logo/alkemical-logo.blend</code>.
      Run <code>just export-logo</code> to generate SVG and PNG exports.
    </p>
  </section>

  <section class="section">
    <h2>Clear Space</h2>
    <p>
      Maintain a minimum clear space equal to the height of the "A" in the
      logotype around all sides of the mark. This ensures the logo reads
      clearly in all contexts.
    </p>
  </section>

  <section class="section">
    <h2>Usage Rules</h2>
    <div class="rules-grid">
      <div class="rule do">
        <h3>Do</h3>
        <ul>
          <li>Use the logo on dark backgrounds (preferred)</li>
          <li>Maintain original proportions</li>
          <li>Use provided color variants</li>
          <li>Link to <code>alkem.dev</code> when using the mark</li>
        </ul>
      </div>
      <div class="rule dont">
        <h3>Don't</h3>
        <ul>
          <li>Stretch or distort the logo</li>
          <li>Add effects like drop shadows or outlines</li>
          <li>Place on busy or low-contrast backgrounds</li>
          <li>Recreate or approximate the mark</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section">
    <h2>Formats Available</h2>
    <table>
      <thead>
        <tr>
          <th>Format</th>
          <th>Use Case</th>
          <th>Path</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>SVG</td>
          <td>Web, print, scalable</td>
          <td><code>out/logo/svg/</code></td>
        </tr>
        <tr>
          <td>PNG (64–1024px)</td>
          <td>Social media, favicons, previews</td>
          <td><code>out/logo/png/</code></td>
        </tr>
        <tr>
          <td>WebP</td>
          <td>Web (optimized)</td>
          <td><code>out/logo/webp/</code></td>
        </tr>
        <tr>
          <td>Blender (.blend)</td>
          <td>Source editing</td>
          <td><code>src/logo/</code></td>
        </tr>
      </tbody>
    </table>
  </section>
</BaseLayout>

<style>
  .page-header {
    padding-bottom: var(--brand-spacing-10);
    border-bottom: 1px solid var(--brand-color-semantic-border);
    margin-bottom: var(--brand-spacing-10);
  }

  .page-header h1 {
    font-size: var(--brand-typography-scale-5xl);
    margin-bottom: var(--brand-spacing-4);
  }

  .page-header p {
    max-width: 40rem;
    color: var(--brand-color-semantic-text-muted);
    font-size: var(--brand-typography-scale-lg);
    line-height: var(--brand-typography-lineHeight-relaxed);
  }

  .section {
    margin-bottom: var(--brand-spacing-12);
  }

  .section h2 {
    font-size: var(--brand-typography-scale-2xl);
    margin-bottom: var(--brand-spacing-4);
  }

  .logo-display {
    padding: var(--brand-spacing-12);
    border: 1px dashed var(--brand-color-semantic-border);
    border-radius: var(--brand-radius-xl);
    text-align: center;
    margin-bottom: var(--brand-spacing-4);
  }

  .logo-placeholder {
    color: var(--brand-color-semantic-text-muted);
    display: flex;
    flex-direction: column;
    gap: var(--brand-spacing-2);
    align-items: center;
  }

  .note {
    font-size: var(--brand-typography-scale-sm);
    color: var(--brand-color-semantic-text-muted);
  }

  .rules-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--brand-spacing-4);
  }

  .rule {
    padding: var(--brand-spacing-6);
    border-radius: var(--brand-radius-lg);
    border: 1px solid var(--brand-color-semantic-border);
  }

  .rule h3 {
    font-size: var(--brand-typography-scale-lg);
    margin-bottom: var(--brand-spacing-3);
  }

  .do h3 { color: var(--brand-color-primitive-gold-400); }
  .dont h3 { color: var(--brand-color-primitive-ember-400); }

  .rule ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--brand-spacing-2);
  }

  .rule li {
    font-size: var(--brand-typography-scale-sm);
    color: var(--brand-color-semantic-text-muted);
    padding-left: var(--brand-spacing-4);
    position: relative;
  }

  .do li::before { content: "✓"; position: absolute; left: 0; color: var(--brand-color-primitive-gold-400); }
  .dont li::before { content: "✗"; position: absolute; left: 0; color: var(--brand-color-primitive-ember-400); }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--brand-typography-scale-sm);
  }

  th, td {
    text-align: left;
    padding: var(--brand-spacing-3) var(--brand-spacing-4);
    border-bottom: 1px solid var(--brand-color-semantic-border-subtle);
  }

  th {
    color: var(--brand-color-semantic-text-muted);
    font-weight: var(--brand-typography-weight-medium);
    text-transform: uppercase;
    letter-spacing: var(--brand-typography-letterSpacing-wider);
    font-size: var(--brand-typography-scale-xs);
  }

  @media (max-width: 640px) {
    .rules-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
