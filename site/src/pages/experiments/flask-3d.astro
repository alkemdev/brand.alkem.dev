---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="3D Flask Experiment"
  description="Generative 3D flask: torus base, straight cone, constant neck, lip. Surface of revolution; adjust parameters and export OBJ."
>
  <div class="flask-3d-page">
    <header class="page-header">
      <h1>3D Generative Flask</h1>
      <p class="lead">
        A flask from <strong>first principles</strong>: it’s a <strong>surface of revolution</strong>.
        The shape is a single radius profile <code>r(y)</code> — at each height <em>y</em>, the flask has radius <em>r</em>.
        Rotate that profile around the vertical axis to get the 3D mesh: <strong>torus-like base</strong> → <strong>straight cone</strong> → <strong>constant-radius neck</strong> → <strong>lip bump</strong>.
      </p>
    </header>

    <div class="flask-3d-layout">
      <div class="canvas-wrap">
        <canvas id="flask-3d-canvas" aria-label="3D flask view"></canvas>
        <div class="canvas-overlay">
          <span id="flask-3d-status">Loading…</span>
        </div>
      </div>

      <aside class="controls-panel">
        <h2>Profile parameters</h2>
        <p class="control-hint">Unit scale. Drag canvas to rotate; scroll to zoom.</p>

        <div class="control-row">
          <div class="control-meta">
            <label for="baseHeight">Base height</label>
            <span id="baseHeightVal" class="control-val">0.05</span>
          </div>
          <span class="control-doc">Torus-like rounded base (arc height).</span>
          <input type="range" id="baseHeight" min="0.02" max="0.12" step="0.005" value="0.05" />
        </div>
        <div class="control-row">
          <div class="control-meta">
            <label for="baseRadius">Base radius</label>
            <span id="baseRadiusVal" class="control-val">0.20</span>
          </div>
          <span class="control-doc">Radius where base meets the cone.</span>
          <input type="range" id="baseRadius" min="0.05" max="0.4" step="0.01" value="0.2" />
        </div>
        <div class="control-row">
          <div class="control-meta">
            <label for="bodyHeight">Cone height</label>
            <span id="bodyHeightVal" class="control-val">0.45</span>
          </div>
          <span class="control-doc">Straight cone from base to neck.</span>
          <input type="range" id="bodyHeight" min="0.2" max="0.7" step="0.01" value="0.45" />
        </div>
        <div class="control-row">
          <div class="control-meta">
            <label for="neckRadius">Neck radius</label>
            <span id="neckRadiusVal" class="control-val">0.07</span>
          </div>
          <span class="control-doc">Cylinder radius (constant section).</span>
          <input type="range" id="neckRadius" min="0.02" max="0.2" step="0.01" value="0.07" />
        </div>
        <div class="control-row">
          <div class="control-meta">
            <label for="neckHeight">Neck height</label>
            <span id="neckHeightVal" class="control-val">0.20</span>
          </div>
          <span class="control-doc">Length of constant-radius neck.</span>
          <input type="range" id="neckHeight" min="0.08" max="0.5" step="0.01" value="0.2" />
        </div>
        <div class="control-row">
          <div class="control-meta">
            <label for="lipHeight">Lip height</label>
            <span id="lipHeightVal" class="control-val">0.03</span>
          </div>
          <span class="control-doc">Vertical span of the lip bump.</span>
          <input type="range" id="lipHeight" min="0.01" max="0.08" step="0.005" value="0.03" />
        </div>
        <div class="control-row">
          <div class="control-meta">
            <label for="lipBump">Lip bump</label>
            <span id="lipBumpVal" class="control-val">0.015</span>
          </div>
          <span class="control-doc">Outward bulge at the rim.</span>
          <input type="range" id="lipBump" min="0" max="0.04" step="0.005" value="0.015" />
        </div>

        <div class="control-actions">
          <button type="button" id="downloadObj" class="btn-primary">Download OBJ</button>
          <button type="button" id="resetParams" class="btn-secondary">Reset</button>
        </div>
      </aside>
    </div>

    <section class="doc-section">
      <h2>Model</h2>
      <p>
        Profile: <strong>torus-like base</strong> (circular arc tangent to the axis at the bottom), then a <strong>straight cone</strong> to the neck,
        then <strong>constant radius</strong> for the neck, then a small <strong>lip bump</strong> at the rim.
        The base arc and cone/neck/lip are driven by the sliders; the same math drives the 3D viewer and OBJ export.
      </p>
    </section>
  </div>
</BaseLayout>

<style>
  .flask-3d-page {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1.5rem;
  }
  .page-header {
    margin-bottom: 1.5rem;
  }
  .page-header h1 {
    font-size: 1.75rem;
    margin-bottom: 0.5rem;
  }
  .lead {
    font-size: 1rem;
    line-height: 1.5;
    color: var(--text-muted, #555);
  }
  .lead code {
    background: var(--bg-code, #eee);
    padding: 0.1em 0.35em;
    border-radius: 3px;
  }
  .flask-3d-layout {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 1.5rem;
    align-items: start;
  }
  @media (max-width: 768px) {
    .flask-3d-layout {
      grid-template-columns: 1fr;
    }
  }
  .canvas-wrap {
    position: relative;
    background: #1a1a1e;
    border-radius: 8px;
    overflow: hidden;
    aspect-ratio: 1;
    min-height: 320px;
  }
  #flask-3d-canvas {
    display: block;
    width: 100%;
    height: 100%;
  }
  .canvas-overlay {
    position: absolute;
    bottom: 8px;
    left: 8px;
    right: 8px;
    text-align: center;
    pointer-events: none;
    color: rgba(255,255,255,0.7);
    font-size: 0.85rem;
  }
  .controls-panel {
    background: var(--panel-bg, #f6f6f8);
    padding: 1rem;
    border-radius: 8px;
  }
  .controls-panel h2 {
    font-size: 1rem;
    margin-bottom: 0.35rem;
  }
  .control-hint {
    font-size: 0.8rem;
    color: var(--text-muted, #555);
    margin-bottom: 0.6rem;
  }
  .control-row {
    margin-bottom: 0.5rem;
  }
  .control-row .control-meta {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 0.5rem;
    margin-bottom: 0.15rem;
  }
  .control-row label {
    font-size: 0.82rem;
    font-weight: 600;
  }
  .control-row .control-doc {
    display: block;
    font-size: 0.72rem;
    color: var(--text-muted, #666);
    line-height: 1.25;
    margin-bottom: 0.2rem;
  }
  .control-row .control-val {
    font-size: 0.78rem;
    color: var(--text-muted, #555);
  }
  .control-row input[type="range"] {
    width: 100%;
    min-width: 0;
    display: block;
  }
  .control-actions {
    margin-top: 0.75rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .btn-primary, .btn-secondary {
    padding: 0.5rem 1rem;
    border-radius: 6px;
    font-size: 0.9rem;
    cursor: pointer;
    border: 1px solid transparent;
  }
  .btn-primary {
    background: #e85d2b;
    color: #fff;
  }
  .btn-primary:hover {
    background: #d04e20;
  }
  .btn-secondary {
    background: transparent;
    border-color: #ccc;
    color: #333;
  }
  .btn-secondary:hover {
    background: #eee;
  }
  .doc-section {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid #eee;
  }
  .doc-section h2 {
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
  }
</style>

<script>
  import * as THREE from "three";
  import { OrbitControls } from "three/examples/jsm/controls/OrbitControls.js";
  import { buildFlask, toThreeBufferGeometry, DEFAULT_PARAMS } from "../../lib/flask-3d";

  const canvas = document.getElementById("flask-3d-canvas");
  const statusEl = document.getElementById("flask-3d-status");
  if (!canvas || !statusEl) throw new Error("Missing canvas or status");

  const STORAGE_KEY = "flask-3d-params";

  function getParams() {
    return {
      baseHeight: parseFloat(document.getElementById("baseHeight")?.value ?? "0.05"),
      baseRadius: parseFloat(document.getElementById("baseRadius")?.value ?? "0.2"),
      bodyHeight: parseFloat(document.getElementById("bodyHeight")?.value ?? "0.45"),
      neckRadius: parseFloat(document.getElementById("neckRadius")?.value ?? "0.07"),
      neckHeight: parseFloat(document.getElementById("neckHeight")?.value ?? "0.2"),
      lipHeight: parseFloat(document.getElementById("lipHeight")?.value ?? "0.03"),
      lipBump: parseFloat(document.getElementById("lipBump")?.value ?? "0.015"),
    };
  }

  function setParams(p) {
    const set = (id, val) => {
      const el = document.getElementById(id);
      if (el) el.value = String(val);
      const vEl = document.getElementById(id + "Val");
      if (vEl) vEl.textContent = typeof val === "number" ? (val < 0.01 ? val.toFixed(3) : val.toFixed(2)) : val;
    };
    set("baseHeight", p.baseHeight);
    set("baseRadius", p.baseRadius);
    set("bodyHeight", p.bodyHeight);
    set("neckRadius", p.neckRadius);
    set("neckHeight", p.neckHeight);
    set("lipHeight", p.lipHeight);
    set("lipBump", p.lipBump);
  }

  function saveParams() {
    try {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(getParams()));
    } catch (_) {}
  }

  function loadParams() {
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (!raw) return null;
      const p = JSON.parse(raw);
      const keys = ["baseHeight", "baseRadius", "bodyHeight", "neckRadius", "neckHeight", "lipHeight", "lipBump"];
      if (keys.every((k) => typeof p[k] === "number" && Number.isFinite(p[k]))) return p;
    } catch (_) {}
    return null;
  }

  let scene, camera, renderer, controls, mesh;
  let currentObj = "";

  function init() {
    const width = canvas.clientWidth;
    const height = canvas.clientHeight;
    scene = new THREE.Scene();
    scene.background = new THREE.Color(0x1a1a1e);
    camera = new THREE.PerspectiveCamera(40, width / height, 0.01, 100);
    camera.position.set(2.2, 0.9, 2.2);
    camera.lookAt(0, 0.35, 0);
    renderer = new THREE.WebGLRenderer({ canvas, antialias: true });
    renderer.setSize(width, height);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    if (renderer.outputColorSpace !== undefined) renderer.outputColorSpace = THREE.SRGBColorSpace;
    controls = new OrbitControls(camera, canvas);
    controls.target.set(0, 0.35, 0);
    controls.enableDamping = true;
    controls.dampingFactor = 0.05;
    controls.minDistance = 1.2;
    controls.maxDistance = 5;

    const key = new THREE.DirectionalLight(0xffffff, 1.2);
    key.position.set(2.5, 2.2, 1.8);
    scene.add(key);
    const fill = new THREE.DirectionalLight(0xd8e0e8, 0.5);
    fill.position.set(-1.5, 0.6, 1.2);
    scene.add(fill);
    const rim = new THREE.DirectionalLight(0xffffff, 0.5);
    rim.position.set(-0.5, 1.2, -2);
    scene.add(rim);
    scene.add(new THREE.AmbientLight(0xffffff, 0.2));

    const saved = loadParams();
    setParams(saved ?? DEFAULT_PARAMS);
    buildMesh();
    statusEl.textContent = "Drag to rotate · Scroll to zoom";
  }

  function buildMesh() {
    const params = getParams();
    const { mesh: meshData, obj } = buildFlask(params, {
      verticalSegments: 72,
      azimuthSegments: 48,
    });
    currentObj = obj;

    if (mesh) scene.remove(mesh);
    if (mesh?.geometry) mesh.geometry.dispose();

    const geometry = toThreeBufferGeometry(meshData, THREE);
    const material = new THREE.MeshStandardMaterial({
      color: 0xf2f2f6,
      roughness: 0.28,
      metalness: 0.08,
      side: THREE.DoubleSide,
      flatShading: false,
    });
    mesh = new THREE.Mesh(geometry, material);
    scene.add(mesh);
  }

  function animate() {
    requestAnimationFrame(animate);
    controls.update();
    renderer.render(scene, camera);
  }

  function onResize() {
    const width = canvas.clientWidth;
    const height = canvas.clientHeight;
    camera.aspect = width / height;
    camera.updateProjectionMatrix();
    renderer.setSize(width, height);
  }

  window.addEventListener("resize", onResize);

  const sliderIds = [
    "baseHeight", "baseRadius", "bodyHeight", "neckRadius", "neckHeight", "lipHeight", "lipBump",
  ];
  sliderIds.forEach((id) => {
    const input = document.getElementById(id);
    const valEl = document.getElementById(id + "Val");
    if (input && valEl) {
      input.addEventListener("input", () => {
        const val = parseFloat(input.value);
        valEl.textContent = val < 0.01 ? val.toFixed(3) : val.toFixed(2);
        saveParams();
        buildMesh();
      });
    }
  });

  document.getElementById("downloadObj")?.addEventListener("click", () => {
    const blob = new Blob([currentObj], { type: "text/plain" });
    const a = document.createElement("a");
    a.href = URL.createObjectURL(blob);
    a.download = "alkemical-flask-3d.obj";
    a.click();
    URL.revokeObjectURL(a.href);
  });

  document.getElementById("resetParams")?.addEventListener("click", () => {
    setParams(DEFAULT_PARAMS);
    saveParams();
    buildMesh();
  });

  init();
  animate();
</script>
